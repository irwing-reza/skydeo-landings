---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
	title="Somegraph | Clarity for complex data"
	description="A sample Skydeo landing page routed from somegraph.skydeo.com."
>
	<main id="main-content">
		<section class="hero">
			<div class="container hero__grid">
				<div>
					<p class="eyebrow">Somegraph by Skydeo</p>
					<h1>Turn complex signals into clear decisions.</h1>
					<p class="hero__copy">
						A focused example landing page showing how every subdomain can have its own
						content while sharing the Skydeo foundation.
					</p>
					<div class="hero__actions">
						<a class="button button--primary" href="/details">Explore the example</a>
						<a class="button button--secondary" href="https://skydeo.com">Visit Skydeo</a>
					</div>
				</div>
				<div class="signal-card" aria-label="Illustrative signal overview">
					<span class="signal-card__label">Live signal</span>
					<strong>87%</strong>
					<div class="signal-card__track"><span></span></div>
					<p>Clarity score across your current campaign.</p>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.hero {
		display: grid;
		min-height: 100vh;
		place-items: center;
		overflow: hidden;
		padding-block: clamp(5rem, 12vw, 9rem);
		background:
			linear-gradient(130deg, transparent 45%, rgb(0 122 98 / 0.07)),
			var(--color-surface);
	}

	.hero__grid {
		display: grid;
		align-items: center;
		gap: clamp(3rem, 8vw, 8rem);
	}

	h1 {
		max-width: 12ch;
		margin: 0;
		font-size: clamp(3.2rem, 9vw, 7.5rem);
		letter-spacing: -0.06em;
	}

	.hero__copy {
		max-width: 42rem;
		margin: 1.5rem 0 0;
		color: var(--color-text-muted);
		font-size: clamp(1.05rem, 2vw, 1.25rem);
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 2rem;
	}

	.button {
		display: inline-flex;
		min-height: 3rem;
		align-items: center;
		justify-content: center;
		padding: 0.7rem 1.15rem;
		border: 1px solid transparent;
		border-radius: var(--radius-md);
		font-weight: 700;
		text-decoration: none;
		transition:
			background-color 180ms ease,
			border-color 180ms ease,
			transform 180ms ease;
	}

	.button:hover {
		transform: translateY(-2px);
	}

	.button--primary {
		color: white;
		background: var(--color-brand-green);
	}

	.button--primary:hover {
		background: var(--color-brand-green-hover);
	}

	.button--secondary {
		border-color: var(--color-border);
		color: var(--color-text);
		background: white;
	}

	.signal-card {
		position: relative;
		padding: clamp(1.5rem, 4vw, 2.5rem);
		border: 1px solid rgb(255 255 255 / 0.8);
		border-radius: var(--radius-lg);
		background: linear-gradient(145deg, var(--color-brand-navy), #1c3440);
		box-shadow: var(--shadow-card);
		color: white;
	}

	.signal-card::before {
		position: absolute;
		z-index: -1;
		inset: -15%;
		border-radius: 50%;
		background: var(--color-brand-green);
		content: '';
		filter: blur(5rem);
		opacity: 0.18;
	}

	.signal-card__label {
		color: #a6e4d5;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.signal-card strong {
		display: block;
		margin-block: 0.6rem;
		font-family: var(--font-heading);
		font-size: clamp(4rem, 10vw, 7rem);
		letter-spacing: -0.05em;
		line-height: 1;
	}

	.signal-card__track {
		height: 0.6rem;
		overflow: hidden;
		border-radius: 999px;
		background: rgb(255 255 255 / 0.15);
	}

	.signal-card__track span {
		display: block;
		width: 87%;
		height: 100%;
		border-radius: inherit;
		background: #76d7bf;
	}

	.signal-card p {
		margin-bottom: 0;
		color: rgb(255 255 255 / 0.7);
	}

	@media (min-width: 54rem) {
		.hero__grid {
			grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.8fr);
		}
	}
</style>
