---
import skydeoLogo from '../../../assets/brand/logo.svg';
import Layout from '../../../layouts/Layout.astro';

const audiences = [
	{
		label: 'Dining behavior',
		title: 'Taco regulars',
		copy: 'Reach people whose real-world dining patterns show an affinity for tacos, taquerias, and Mexican food.',
	},
	{
		label: 'Restaurant preference',
		title: 'QSR & casual diners',
		copy: 'Build segments around quick-service routines, casual dining, competitive visits, and brand loyalty.',
	},
	{
		label: 'Meal occasions',
		title: 'Delivery & carryout',
		copy: 'Connect campaigns to convenient meal moments, from weekday dinner to late-night and group orders.',
	},
	{
		label: 'Retail connection',
		title: 'At-home taco makers',
		copy: 'Find shoppers interested in tortillas, salsas, seasonings, proteins, and other Mexican-food ingredients.',
	},
];

const useCases = [
	{
		number: '01',
		title: 'Restaurant promotions',
		copy: 'Reach category diners for openings, limited-time offers, loyalty growth, and competitive conquesting.',
	},
	{
		number: '02',
		title: 'Delivery campaigns',
		copy: 'Shape acquisition and re-engagement around delivery, carryout, convenience, and meal occasions.',
	},
	{
		number: '03',
		title: 'CPG activation',
		copy: 'Connect restaurant interest with relevant grocery categories and retail media audiences.',
	},
	{
		number: '04',
		title: 'Local market planning',
		copy: 'Compare category interest and competitive behavior market by market before you place spend.',
	},
];
---

<Layout
	title="Taco & Mexican Food Audience Data | TacoGraph by Skydeo"
	description="Build advertising audiences from taco and Mexican food dining signals for restaurant, delivery, CPG, retail media, and local-market campaigns."
>
	<Fragment slot="head">
		<link rel="canonical" href="https://tacograph.skydeo.com/" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content="TacoGraph™ by Skydeo" />
		<meta property="og:description" content="Category-specific audience signals for the people, places, and occasions shaping taco and Mexican food demand." />
		<meta property="og:url" content="https://tacograph.skydeo.com/" />
	</Fragment>

	<header class="site-header">
		<div class="container site-header__inner">
			<a class="brand" href="https://skydeo.com" aria-label="Skydeo home">
				<img src={skydeoLogo.src} alt="" width="121" height="39" />
			</a>
			<nav aria-label="Page navigation">
				<a href="#audiences">Audiences</a>
				<a href="#use-cases">Use cases</a>
				<a href="#how-it-works">How it works</a>
			</nav>
			<a class="header-cta" href="https://sam.skydeo.com/create-account">Build an audience <span aria-hidden="true">↗</span></a>
		</div>
	</header>

	<main id="main-content">
		<section class="hero">
			<div class="container hero__grid">
				<div class="hero__copy">
					<p class="product-label"><span></span>TacoGraph™ by Skydeo</p>
					<h1>Know who’s hungry for <em>what’s next.</em></h1>
					<p class="hero__lede">Turn taco and Mexican food dining behavior into focused audiences for restaurant, delivery, CPG, retail media, and local-market campaigns.</p>
					<div class="hero__actions">
						<a class="button button--primary" href="https://sam.skydeo.com/create-account">Build an audience <span aria-hidden="true">→</span></a>
						<a class="button button--text" href="#audiences">Explore the signals <span aria-hidden="true">↓</span></a>
					</div>
					<p class="hero__note">Category-specific signals. Privacy-conscious activation. Built for real campaign planning.</p>
				</div>

				<div class="signal-map" aria-label="Illustration of TacoGraph connecting dining, delivery, retail, and local market signals">
					<div class="signal-map__rings" aria-hidden="true"><span></span><span></span><span></span></div>
					<div class="signal-map__core"><span>TacoGraph</span><strong>Category<br />signal</strong><small>Audience ready</small></div>
					<div class="signal signal--one"><i></i><span>Dining</span></div>
					<div class="signal signal--two"><i></i><span>Delivery</span></div>
					<div class="signal signal--three"><i></i><span>Retail</span></div>
					<div class="signal signal--four"><i></i><span>Local markets</span></div>
				</div>
			</div>
			<div class="container hero__rail" aria-label="TacoGraph signal coverage">
				<span>Tacos</span><i></i><span>Mexican food</span><i></i><span>QSR</span><i></i><span>Food trucks</span><i></i><span>Delivery</span><i></i><span>Grocery</span>
			</div>
		</section>

		<section class="intro">
			<div class="container intro__grid">
				<div>
					<p class="eyebrow">A clearer category view</p>
					<h2>Mexican food is not one audience.</h2>
				</div>
				<div>
					<p>It is a web of restaurant preferences, delivery habits, shopping signals, and meal occasions. TacoGraph helps marketing teams separate those behaviors—and turn the right combination into an activation-ready audience.</p>
					<a class="arrow-link" href="#how-it-works">See how signals become strategy <span aria-hidden="true">→</span></a>
				</div>
			</div>
		</section>

		<section class="audiences section" id="audiences">
			<div class="container section-heading">
				<div><p class="eyebrow">Audience building blocks</p><h2>Start with the behavior that matters.</h2></div>
				<p>Combine category-specific signals to move beyond broad food interest and toward the people most relevant to your campaign.</p>
			</div>
			<div class="container audience-grid">
				{audiences.map((audience, index) => (
					<article>
						<div class="card-top"><span>{String(index + 1).padStart(2, '0')}</span><i aria-hidden="true"></i></div>
						<p>{audience.label}</p>
						<h3>{audience.title}</h3>
						<div class="mini-signal" aria-hidden="true">{Array.from({ length: 7 }).map((_, signalIndex) => <span style={`--level:${((signalIndex * 3 + index * 2) % 7) + 2}`}></span>)}</div>
						<small>{audience.copy}</small>
					</article>
				))}
			</div>
		</section>

		<section class="use-cases section" id="use-cases">
			<div class="container section-heading section-heading--light">
				<div><p class="eyebrow">Built for activation</p><h2>One category graph. Many ways to grow.</h2></div>
				<p>Use TacoGraph across planning, audience creation, and activation—whether the meal happens in a restaurant, arrives at the door, or starts in a grocery aisle.</p>
			</div>
			<div class="container use-case-list">
				{useCases.map((item) => (
					<article><span>{item.number}</span><h3>{item.title}</h3><p>{item.copy}</p><i aria-hidden="true">↗</i></article>
				))}
			</div>
		</section>

		<section class="process section" id="how-it-works">
			<div class="container process__grid">
				<div class="process__copy">
					<p class="eyebrow">How TacoGraph works</p>
					<h2>From category behavior to campaign-ready.</h2>
					<p>TacoGraph organizes privacy-conscious behavioral signals into useful audience inputs. Your team chooses the category lens, refines it for the campaign, and activates the resulting audience through Skydeo.</p>
				</div>
				<ol class="process-list">
					<li><span>01</span><div><h3>Choose your category lens</h3><p>Start with tacos, Mexican food, restaurant formats, delivery, grocery ingredients, or a connected behavior.</p></div></li>
					<li><span>02</span><div><h3>Shape the audience</h3><p>Layer affinities, visits, shopping behavior, geography, and meal occasions around your campaign goal.</p></div></li>
					<li><span>03</span><div><h3>Plan and activate</h3><p>Use the segment for media activation, partner strategy, market prioritization, or campaign planning.</p></div></li>
				</ol>
			</div>
		</section>

		<section class="teams section">
			<div class="container teams__inner">
				<p class="eyebrow">Made for modern marketing teams</p>
				<h2>Category intelligence your whole team can use.</h2>
				<div class="team-list" aria-label="Teams TacoGraph supports">
					<span>Brands</span><span>Agencies</span><span>Restaurant groups</span><span>Delivery platforms</span><span>Retail media teams</span>
				</div>
			</div>
		</section>

		<section class="final-cta">
			<div class="container final-cta__inner">
				<p class="eyebrow">Put TacoGraph to work</p>
				<h2>Build an audience around the way people actually eat.</h2>
				<p>Start with a category. Add the signals that matter. Turn your next restaurant, delivery, CPG, or local-market idea into a focused audience.</p>
				<a class="button button--light" href="https://sam.skydeo.com/create-account">Build an audience <span aria-hidden="true">→</span></a>
			</div>
		</section>
	</main>

	<footer>
		<div class="container footer__inner">
			<a class="brand" href="https://skydeo.com" aria-label="Skydeo home"><img src={skydeoLogo.src} alt="" width="121" height="39" /></a>
			<p>TacoGraph™ is a category-specific audience solution by Skydeo.</p>
			<small>© 2026 Skydeo. All rights reserved.</small>
		</div>
	</footer>
</Layout>

<style>
	:global(html) { scroll-padding-top: 5rem; }
	:global(body) { background: #fffdf8; }
	.site-header { position: sticky; z-index: 20; top: 0; border-bottom: 1px solid rgb(16 24 40 / .08); background: rgb(255 253 248 / .94); backdrop-filter: blur(16px); }
	.site-header__inner { display: flex; min-height: 4.75rem; align-items: center; justify-content: space-between; gap: 1.25rem; }
	.brand { display: inline-flex; flex: 0 0 auto; align-items: center; }
	.brand :global(img) { width: 6.6rem; height: auto; }
	nav { display: none; gap: 2rem; }
	nav a { color: #3b4642; font-size: .79rem; font-weight: 750; text-decoration: none; }
	nav a:hover { color: var(--color-brand-green); }
	.header-cta { display: inline-flex; min-height: 2.85rem; align-items: center; gap: .7rem; padding: .6rem 1rem; border-radius: 999px; color: white; background: #102a25; font-size: .75rem; font-weight: 800; text-decoration: none; }
	.header-cta:hover { background: var(--color-brand-green); }
	.hero { position: relative; overflow: hidden; color: white; background: #102a25; }
	.hero::before { position: absolute; width: 52rem; height: 52rem; top: -34rem; left: 48%; border-radius: 50%; background: #e7683d; content: ''; filter: blur(9rem); opacity: .2; }
	.hero::after { position: absolute; width: 36rem; height: 36rem; right: -20rem; bottom: -18rem; border-radius: 50%; background: #58c9a7; content: ''; filter: blur(8rem); opacity: .18; }
	.hero__grid { position: relative; z-index: 1; display: grid; min-height: 43rem; align-items: center; gap: 2rem; padding-block: clamp(4.5rem, 9vw, 7.5rem); }
	.product-label { display: flex; align-items: center; gap: .65rem; margin: 0 0 1.6rem; color: #9ee3ce; font-size: .72rem; font-weight: 850; letter-spacing: .12em; text-transform: uppercase; }
	.product-label span { width: .55rem; height: .55rem; border-radius: 50%; background: #e97850; box-shadow: 0 0 0 .35rem rgb(233 120 80 / .15); }
	h1 { max-width: 10ch; margin: 0; font-size: clamp(3.6rem, 9vw, 7.5rem); letter-spacing: -.075em; line-height: .9; }
	h1 em { color: #f08a65; font-style: normal; }
	.hero__lede { max-width: 43rem; margin: 1.75rem 0 0; color: #b9ccc6; font-size: clamp(1.05rem, 2vw, 1.25rem); }
	.hero__actions { display: flex; flex-wrap: wrap; align-items: center; gap: 1.2rem; margin-top: 2rem; }
	.button { display: inline-flex; min-height: 3.2rem; align-items: center; justify-content: center; gap: 1.25rem; padding: .7rem 1.15rem; border: 1px solid transparent; border-radius: .45rem; font-size: .84rem; font-weight: 850; text-decoration: none; transition: transform 180ms ease, background 180ms ease; }
	.button:hover { transform: translateY(-2px); }
	.button--primary { color: #102a25; background: #8ee2c8; }
	.button--primary:hover { background: #afeedb; }
	.button--text { color: white; }
	.hero__note { margin: 1.3rem 0 0; color: #758f87; font-size: .72rem; }
	.signal-map { position: relative; min-height: 24rem; display: grid; place-items: center; }
	.signal-map__rings span { position: absolute; inset: 50% auto auto 50%; border: 1px solid rgb(142 226 200 / .18); border-radius: 50%; transform: translate(-50%, -50%); }
	.signal-map__rings span:nth-child(1) { width: 14rem; height: 14rem; }
	.signal-map__rings span:nth-child(2) { width: 21rem; height: 21rem; border-style: dashed; }
	.signal-map__rings span:nth-child(3) { width: 28rem; height: 28rem; opacity: .5; }
	.signal-map__core { position: relative; z-index: 2; display: flex; width: 10.5rem; aspect-ratio: 1; flex-direction: column; justify-content: center; padding: 1.45rem; border: 1px solid rgb(255 255 255 / .25); border-radius: 50%; background: radial-gradient(circle at 35% 22%, #375f55, #17352e 66%); box-shadow: 0 2rem 4rem rgb(0 0 0 / .35); }
	.signal-map__core span, .signal-map__core small { color: #8ee2c8; font-size: .58rem; font-weight: 800; letter-spacing: .11em; text-transform: uppercase; }
	.signal-map__core strong { margin: .45rem 0 .6rem; font-family: var(--font-heading); font-size: 1.45rem; line-height: .95; }
	.signal { position: absolute; z-index: 3; display: flex; align-items: center; gap: .45rem; padding: .45rem .65rem; border: 1px solid rgb(255 255 255 / .16); border-radius: 999px; color: #d6e5e0; background: rgb(13 38 32 / .88); font-size: .65rem; font-weight: 750; }
	.signal i { width: .42rem; height: .42rem; border-radius: 50%; background: #ee7e57; }
	.signal--one { top: 8%; left: 8%; }.signal--two { top: 18%; right: 1%; }.signal--three { right: 3%; bottom: 14%; }.signal--four { bottom: 7%; left: 2%; }
	.hero__rail { position: relative; z-index: 2; display: flex; overflow: hidden; align-items: center; gap: 1.2rem; padding-block: 1.25rem; border-top: 1px solid rgb(255 255 255 / .12); color: #91a8a1; white-space: nowrap; font-size: .68rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
	.hero__rail i { width: .28rem; height: .28rem; flex: 0 0 auto; border-radius: 50%; background: #e97850; }
	.intro, .section { padding-block: clamp(5rem, 10vw, 9rem); }
	.intro { background: #fffdf8; }
	.intro__grid { display: grid; gap: 2.5rem; }
	.eyebrow { color: #087961; }
	h2 { margin: 0; font-size: clamp(2.7rem, 6vw, 5.25rem); letter-spacing: -.06em; line-height: .96; }
	.intro h2 { max-width: 11ch; }
	.intro__grid > div:last-child { align-self: end; }
	.intro__grid > div:last-child > p { max-width: 38rem; margin: 0; color: #59645f; font-size: 1.08rem; }
	.arrow-link { display: inline-flex; gap: 1rem; margin-top: 1.5rem; color: #102a25; font-size: .78rem; font-weight: 850; text-decoration: none; }
	.section-heading { display: grid; gap: 2rem; margin-bottom: clamp(3rem, 7vw, 5rem); }
	.section-heading h2 { max-width: 11ch; }
	.section-heading > p { max-width: 37rem; margin: 0; align-self: end; color: #5d6964; }
	.audiences { background: #e9f6f0; }
	.audience-grid { display: grid; gap: .9rem; }
	.audience-grid article { padding: 1.5rem; border: 1px solid #b9d9ce; border-radius: .8rem; background: rgb(255 255 255 / .6); }
	.card-top { display: flex; align-items: center; justify-content: space-between; color: #087961; font-size: .65rem; font-weight: 850; }
	.card-top i { width: .55rem; height: .55rem; border-radius: 50%; background: #e97850; box-shadow: 0 0 0 .35rem rgb(233 120 80 / .13); }
	.audience-grid article > p { margin: 2.4rem 0 .35rem; color: #087961; font-size: .66rem; font-weight: 850; letter-spacing: .08em; text-transform: uppercase; }
	.audience-grid h3 { margin: 0; font-size: 1.5rem; letter-spacing: -.035em; }
	.audience-grid small { display: block; color: #5d6964; }
	.mini-signal { display: flex; height: 4rem; align-items: end; gap: .28rem; margin: 1.4rem 0; }
	.mini-signal span { width: 14.28%; height: calc(var(--level) * 10%); min-height: .5rem; border-radius: 2px 2px 0 0; background: #0f8b70; opacity: calc(.38 + var(--level) * .06); }
	.use-cases { color: white; background: #102a25; }
	.section-heading--light .eyebrow { color: #8ee2c8; }
	.section-heading--light > p { color: #9eb3ad; }
	.use-case-list { border-top: 1px solid rgb(255 255 255 / .14); }
	.use-case-list article { position: relative; display: grid; gap: .65rem; padding: 1.6rem 0; border-bottom: 1px solid rgb(255 255 255 / .14); }
	.use-case-list article > span { color: #ee8b68; font-size: .67rem; font-weight: 850; }
	.use-case-list h3 { margin: 0; font-size: clamp(1.5rem, 4vw, 2.1rem); letter-spacing: -.04em; }
	.use-case-list p { max-width: 35rem; margin: 0; color: #95aaa4; font-size: .88rem; }
	.use-case-list i { position: absolute; top: 1.6rem; right: 0; color: #8ee2c8; font-style: normal; }
	.process { background: #f5efe4; }
	.process__grid { display: grid; gap: 4rem; }
	.process__copy h2 { max-width: 11ch; }
	.process__copy > p:last-child { max-width: 35rem; color: #615f58; }
	.process-list { margin: 0; padding: 0; border-top: 1px solid #cbc7bc; list-style: none; }
	.process-list li { display: grid; grid-template-columns: 2rem 1fr; gap: 1rem; padding: 1.5rem 0; border-bottom: 1px solid #cbc7bc; }
	.process-list li > span { color: #087961; font-size: .68rem; font-weight: 900; }
	.process-list h3 { margin: 0 0 .45rem; font-size: 1.25rem; }
	.process-list p { margin: 0; color: #65645e; font-size: .88rem; }
	.teams { padding-block: clamp(4rem, 8vw, 7rem); background: #fffdf8; }
	.teams__inner { text-align: center; }
	.teams h2 { max-width: 16ch; margin-inline: auto; }
	.team-list { display: flex; flex-wrap: wrap; justify-content: center; gap: .7rem; margin-top: 2.5rem; }
	.team-list span { padding: .65rem .9rem; border: 1px solid #d6d5cd; border-radius: 999px; color: #4f5955; font-size: .72rem; font-weight: 800; }
	.final-cta { color: white; background: #e56f47; }
	.final-cta__inner { padding-block: clamp(5rem, 11vw, 9rem); }
	.final-cta .eyebrow { color: #40251e; }
	.final-cta h2 { max-width: 14ch; }
	.final-cta p:not(.eyebrow) { max-width: 42rem; color: #4d2e25; font-size: 1.05rem; }
	.button--light { margin-top: 1.25rem; color: #102a25; background: white; }
	footer { color: white; background: #102a25; }
	.footer__inner { padding-block: 3rem; }
	.footer__inner p { max-width: 30rem; color: #92a8a1; }
	.footer__inner small { color: #6d8780; }
	@media (min-width: 42rem) {
		.audience-grid { grid-template-columns: 1fr 1fr; }
		.use-case-list article { grid-template-columns: 3rem minmax(12rem, .7fr) 1fr; align-items: start; gap: 1.5rem; }
		.use-case-list p { padding-right: 2.5rem; }
	}
	@media (min-width: 55rem) {
		nav { display: flex; }
		.hero__grid { grid-template-columns: minmax(0, 1.15fr) minmax(22rem, .85fr); gap: 4rem; }
		.signal-map { min-height: 32rem; }
		.intro__grid, .section-heading { grid-template-columns: 1.15fr .85fr; }
		.audience-grid { grid-template-columns: repeat(4, 1fr); }
		.process__grid { grid-template-columns: .9fr 1.1fr; }
	}
	@media (max-width: 24rem) {
		.header-cta { padding-inline: .75rem; font-size: .68rem; }
		.header-cta span { display: none; }
		.signal-map { transform: scale(.84); }
	}
</style>
